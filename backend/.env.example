# Where forecast caches are written. One sub-directory per refresh; an
# atomically-swapped `latest` symlink points at the freshest complete one.
PLUVIO_CACHE_ROOT=./var/forecasts

# KMI mobile-app API base URL. Default works for production.
PLUVIO_KMI_BASE_URL=https://app.meteo.be/services/appv4/

# How far we let the cache fall behind before /healthz reports degraded.
PLUVIO_CACHE_STALE_AFTER_SECONDS=900

# API host/port for `pluvio-api`.
PLUVIO_API_HOST=0.0.0.0
PLUVIO_API_PORT=8000

# Optional: pin the model version label that appears in API responses.
PLUVIO_MODEL_VERSION=stub-0.1

# Optional: comma-separated origin allow-list for CORS.
# Leave empty to disable CORS; "*" to allow all (dev only).
PLUVIO_CORS_ORIGINS=

# ── Traefik / TLS (production only — `docker compose --profile prod up`) ──
# Public hostname the API answers on. Must resolve to this host.
PLUVIO_DOMAIN=pluvio.appmire.be

# Contact address Let's Encrypt requires. Use a real mailbox so you get
# the expiry-warning emails.
ACME_EMAIL=admin@appmire.be
